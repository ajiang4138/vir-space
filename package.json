{
  "name": "vir-space",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop peer-to-peer multi-user virtual remote workspace scaffold",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron -r ts-node/register/transpile-only electron/main.ts",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc -p tsconfig.json --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "start": "electron dist-electron/main.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "package:desktop": "npm run build && electron-builder"
  },
  "dependencies": {
    "@libp2p/bootstrap": "^12.0.15",
    "@libp2p/identify": "^4.0.14",
    "@libp2p/kad-dht": "^16.1.7",
    "@libp2p/mdns": "^12.0.15",
    "@libp2p/mplex": "^12.0.15",
    "@libp2p/noise": "^1.0.1",
    "@libp2p/tcp": "^11.0.14",
    "@libp2p/websockets": "^10.1.7",
    "libp2p": "^3.1.7",
    "it-all": "^3.0.9",
    "uint8arrays": "^5.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5",
    "@types/jest": "^29.5.11"
  },
  "build": {
    "appId": "com.virspace.app",
    "productName": "Vir Space",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
