{
  "name": "vir-space-client",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:watch\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron dist-electron/electron/main.js",
    "dev:electron:watch": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "build:electron": "tsc -p tsconfig.node.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "build": "npm run typecheck && vite build && npm run build:electron && node -e \"require('fs').rmSync('./dist-server', {recursive:true, force:true}); require('fs').cpSync('../server/dist', './dist-server', {recursive:true});\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.virspace.app",
    "productName": "VIR Space",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "dist-server/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "bittorrent-tracker": "^11.2.2",
    "create-torrent": "^6.1.0",
    "parse-torrent": "^11.0.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-sketch-canvas": "^6.2.0",
    "webtorrent": "^2.8.5",
    "ws": "^8.18.3",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.3",
    "wait-on": "^8.0.3"
  }
}
