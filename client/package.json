{
  "name": "vir-space-client",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:watch\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron dist-electron/electron/main.js",
    "dev:electron:watch": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "build:electron": "tsc -p tsconfig.node.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "build": "npm run typecheck && vite build && npm run build:electron"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-sketch-canvas": "^6.2.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "typescript": "^5.8.3",
    "vite": "^5.4.17",
    "wait-on": "^8.0.3"
  }
}
